{
  "name": "pux",
  "version": "1.0.0",
  "description": "Package CI failures into AI-ready local context.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "pux": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.tsx --format esm --target node22 --clean",
    "dev": "tsx src/cli.tsx",
    "start": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "ink": "^7.1.1",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
