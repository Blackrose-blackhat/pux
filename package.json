{
  "name": "pux.sh",
  "version": "0.1.2",
  "description": "Pux tells you why your build failed before you open GitHub.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "pux": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.tsx --format esm --target node22 --clean",
    "dev": "tsx src/cli.tsx",
    "start": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ci",
    "github-actions",
    "devtools",
    "cli",
    "ai-context",
    "developer-experience"
  ],
  "author": "Blackrose-blackhat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blackrose-blackhat/pux.git"
  },
  "homepage": "https://github.com/Blackrose-blackhat/pux",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "ink": "^7.1.1",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
